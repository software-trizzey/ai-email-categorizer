OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional production categorizer override after comparing eval results.
# Use CATEGORIZER_PROVIDER=self-hosted with an OpenAI-compatible local/private endpoint.
CATEGORIZER_PROVIDER=openai
CATEGORIZER_MODEL=gpt-4o-mini
CATEGORIZER_BASE_URL=
CATEGORIZER_API_KEY=
CATEGORIZER_MAX_TOKENS=

CATEGORIZER_EVAL_URL=http://localhost:3000/eval/categorize
ENABLE_EVAL_ENDPOINTS=false

# Optional OpenTelemetry tracing. Disabled unless OTEL_ENABLED=true.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=ai-email-categorizer
OTEL_SERVICE_VERSION=0.0.0
OTEL_DEPLOYMENT_ENVIRONMENT=development
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# For authenticated OTLP providers, set standard OTEL headers.
# OTEL_EXPORTER_OTLP_TRACES_HEADERS="Authorization=Bearer <token>"
# PostHog analytics SDK config (posthog-node).
# Use the PostHog project token / Project API Key, not a personal API key.
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=https://us.i.posthog.com

RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

DISCORD_WEBHOOK_URL=