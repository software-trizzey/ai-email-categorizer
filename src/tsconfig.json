{
  "compilerOptions": {
    "strict": true,
    "target": "es2022",
    "module": "preserve",
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "services/*": ["src/services/*"],
      "utils/*": ["src/utils/*"]
    }
  }
}