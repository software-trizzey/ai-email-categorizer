{
  "type": "json_schema",
  "json_schema": {
    "name": "email_categorization",
    "strict": true,
    "schema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "explanation": { "type": "string" },
        "serviceTypeId": {
          "type": "string",
          "enum": ["stumpGrinding", "stumpRemoval", "rootRemoval", "treePruning", "unknown"]
        },
        "confidenceScore": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "required": ["explanation", "serviceTypeId", "confidenceScore"]
    }
  }
}
